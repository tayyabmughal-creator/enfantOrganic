# Backend API URL (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api

# Public app URL used for Paymob redirect callbacks (set in Paymob dashboard)
# e.g. https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp number for order confirmation (include country code, no +)
NEXT_PUBLIC_WHATSAPP_PHONE=

# NOTE: Never put PAYMOB_API_KEY, PAYMOB_HMAC_SECRET, or any Paymob secret
# in frontend env vars. All Paymob secrets belong ONLY in the backend .env.
