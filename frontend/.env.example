# Backend API URL (no trailing slash)
# Production value: https://enfhantorganic.itwing.cloud/api
#   Correct spelling is enf-H-antorganic (with the 'h'). The typo
#   "enfantorganic" (no 'h') breaks all browser-side API calls.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api

# Public app URL used for Paymob redirect callbacks (set in Paymob dashboard)
# e.g. https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WhatsApp number for order confirmation (include country code, no +)
NEXT_PUBLIC_WHATSAPP_PHONE=

# Google Maps JavaScript API key (Places + Map pin checkout)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Tag Manager container ID (preferred analytics entrypoint)
NEXT_PUBLIC_GTM_ID=

# Optional direct GA4 measurement ID (used only when GTM ID is not configured)
NEXT_PUBLIC_GA4_ID=

# Optional direct Meta Pixel ID (used only when GTM ID is not configured)
NEXT_PUBLIC_META_PIXEL_ID=

# Snapchat Pixel ID (Snap Ads Manager → Events Manager → Web Pixel)
NEXT_PUBLIC_SNAPCHAT_PIXEL_ID=

# NOTE: Never put PAYMOB_API_KEY, PAYMOB_HMAC_SECRET, or any Paymob secret
# in frontend env vars. All Paymob secrets belong ONLY in the backend .env.
