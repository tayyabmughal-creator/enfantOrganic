# System
.DS_Store
Thumbs.db

# Environment files — never commit real .env values. Only the templates are tracked.
.env
.env.*
!.env.example
!.env.production.example
!backend/.env.example
!frontend/.env.example
!frontend/.env.local.example

# Secrets & TLS material — never commit
*.pem
*.key
!frontend/public/**/*.key
deploy/nginx/certs/
secrets/
credentials.json

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/
env/

# Django local/runtime
db.sqlite3
backend/db.sqlite3
media/
backend/media/
backend/staticfiles/

# Node / Next / Expo
node_modules/
*/node_modules/
frontend/.next/
frontend/.next.*/
frontend/out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# PWA build artifacts — regenerated by next-pwa on every build with
# build-specific chunk hashes. Committing them leads to stale SW precache
# entries that break production hydration.
frontend/public/sw.js
frontend/public/sw.js.map
frontend/public/workbox-*.js
frontend/public/workbox-*.js.map
frontend/public/fallback-*.js
frontend/public/swe-worker-*.js

# Local assistant/graph cache
.codex/
.graphify/

# Build artifacts
dist/
build/
coverage/
reference-images/
