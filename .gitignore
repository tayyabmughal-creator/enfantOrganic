# System
.DS_Store
Thumbs.db

# Environment files — never commit real .env values. Only the templates are tracked.
.env
.env.*
!.env.example
!.env.production.example
!backend/.env.example
!frontend/.env.example
!frontend/.env.local.example

# Secrets & TLS material — never commit
*.pem
*.key
!frontend/public/**/*.key
deploy/nginx/certs/
secrets/
credentials.json

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.venv/
venv/
env/

# Django local/runtime
db.sqlite3
backend/db.sqlite3
media/
backend/media/
backend/staticfiles/

# Node / Next / Expo
node_modules/
*/node_modules/
frontend/.next/
frontend/.next-dev/
frontend/.next.*/
frontend/.next-dev*/
frontend/.next_dev*/
frontend/out/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# PWA build artifacts — regenerated by next-pwa on every build with
# build-specific chunk hashes. Committing them leads to stale SW precache
# entries that break production hydration.
frontend/public/sw.js
frontend/public/sw.js.map
frontend/public/workbox-*.js
frontend/public/workbox-*.js.map
frontend/public/fallback-*.js
frontend/public/swe-worker-*.js

# Local assistant/graph cache
.codex/
.graphify/

# Build artifacts
dist/
build/
coverage/
reference-images/

# Product images — 1.3 GB, deployed once via rsync to each server.
# Never commit; CI/CD does not upload them either (already on server).
Images/

# Client raw archives are source handoff files; production import only needs
# extracted images, so keep zip bundles out of git history.
Images/**/*.zip

# Data exports — customer/reviewer dumps contain PII and product handoffs are
# large; never commit them. The tracked products_export_1.csv stays tracked
# (intentional catalog import); these patterns block stray exports only.
*-data-export.csv
*-reviewer-*.csv
reviewer-data-export.csv
customers_export.csv
customers_export*.csv
*-review-export.csv.xlsx
*-review-export*.xlsx

# Production data dumps — never commit
prod_data.json
prod_db.dump
*.dump
