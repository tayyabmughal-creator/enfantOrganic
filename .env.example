DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0
DJANGO_SESSION_COOKIE_HTTPONLY=1
DJANGO_CSRF_COOKIE_HTTPONLY=1
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=1
DJANGO_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
DJANGO_X_FRAME_OPTIONS=DENY
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0

DRF_AUTH_RATE=20/min
DRF_CHECKOUT_RATE=30/hour
DRF_PAYMENT_RATE=60/hour
DRF_ORDER_LOOKUP_RATE=10/hour

# Shared by backend Celery revalidate task and Next.js /api/revalidate (required in production)
REVALIDATION_SECRET=change-me-in-production
FRONTEND_INTERNAL_URL=http://frontend:3000

POSTGRES_DB=enfantorganic
POSTGRES_USER=enfantorganic
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@example.com

NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_TEMPLATE_ORDER_CONFIRMED=
WHATSAPP_TEMPLATE_ORDER_SHIPPED=
WHATSAPP_TEMPLATE_ORDER_DELIVERED=
