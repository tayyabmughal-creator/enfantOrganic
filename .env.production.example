# Copy this file to .env.production on the server.
# Never commit real production values.
#
# PRODUCTION DOMAIN: https://enfhantorganic.itwing.cloud
#   Correct spelling is enf-H-antorganic (WITH the 'h'). The typo
#   "enfantorganic" (no 'h') has repeatedly broken browser API calls and the
#   region/currency conversion flow. scripts/validate-production-env.sh rejects
#   the typo and a missing domain — run it (or scripts/deploy-production.sh)
#   before every deploy.

COMPOSE_PROJECT_NAME=enfhantorganic
HTTP_PORT=8082

# Replace your-domain.com below with: enfhantorganic.itwing.cloud

DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=your-domain.com,www.your-domain.com,localhost,127.0.0.1,backend
DJANGO_CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SESSION_COOKIE_HTTPONLY=1
DJANGO_CSRF_COOKIE_HTTPONLY=1
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=1
DJANGO_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
DJANGO_X_FRAME_OPTIONS=DENY
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1

DRF_ANON_RATE=60/min
DRF_USER_RATE=600/min
DRF_AUTH_RATE=5/min
DRF_PASSWORD_RESET_RATE=3/hour
DRF_CHECKOUT_RATE=30/hour
DRF_PAYMENT_RATE=30/hour
DRF_ORDER_LOOKUP_RATE=5/hour
DRF_WEBHOOK_RATE=120/min

REVALIDATION_SECRET=replace-with-a-long-random-secret
FRONTEND_INTERNAL_URL=http://frontend:3000
# Public storefront URL used in transactional emails (order tracking, password reset).
FRONTEND_PUBLIC_URL=https://your-domain.com

# Admin CSV export caps — protect against mass data exfiltration.
ADMIN_CSV_MAX_ROWS=10000

# Gunicorn worker / timeout configuration (overrides defaults in docker-compose.prod.yml)
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=60
CELERY_CONCURRENCY=2

POSTGRES_DB=enfantorganic
POSTGRES_USER=enfantorganic
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis password — REQUIRED in production. docker-compose.prod.yml refuses to
# start the redis container without it.
REDIS_PASSWORD=replace-with-a-long-random-redis-password
REDIS_HOST=redis
REDIS_PORT=6379

# Browser-facing API URL. Use your real public domain in production.
NEXT_PUBLIC_API_BASE_URL=https://your-domain.com/api

# ---------------------------------------------------------------------------
# Google Maps (checkout address autocomplete + map pin)
# ---------------------------------------------------------------------------
# CLIENT ACTION: paste the client's own Google Maps JavaScript API key here.
# In Google Cloud Console restrict the key by:
#   - Application restriction: HTTP referrers -> https://your-domain.com/*
#   - API restriction: "Maps JavaScript API" + "Places API" + "Geocoding API"
# Without these APIs enabled the checkout map falls back to manual entry.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---------------------------------------------------------------------------
# Paymob — primary online gateway. Get LIVE creds from the Paymob dashboard.
# ---------------------------------------------------------------------------
# Oman (default account). Replace the TEST integration (65592) with the LIVE
# integration/iframe IDs + HMAC + API key from oman.paymob.com when going live.
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=
PAYMOB_BASE_URL=https://oman.paymob.com/api
PAYMOB_CURRENCY=OMR
# Apple Pay (optional) — Paymob MIGS Apple Pay integration.
PAYMOB_APPLE_PAY_INTEGRATION_ID=
PAYMOB_APPLE_PAY_IFRAME_ID=
NEXT_PUBLIC_PAYMOB_APPLE_PAY_INTEGRATION_ID=
# Saudi Arabia — needs its OWN SAR integration (never reuse Oman's OMR creds).
# Leave blank to keep SA Paymob disabled (shows "being set up" notice).
PAYMOB_API_KEY_SA=
PAYMOB_INTEGRATION_ID_SA=
PAYMOB_IFRAME_ID_SA=
PAYMOB_HMAC_SECRET_SA=
PAYMOB_BASE_URL_SA=https://ksa.paymob.com/api
PAYMOB_CURRENCY_SA=SAR
# UAE — needs its OWN AED integration. Leave blank to keep AE Paymob disabled.
PAYMOB_API_KEY_AE=
PAYMOB_INTEGRATION_ID_AE=
PAYMOB_IFRAME_ID_AE=
PAYMOB_HMAC_SECRET_AE=
PAYMOB_BASE_URL_AE=https://uae.paymob.com/api
PAYMOB_CURRENCY_AE=AED

# ---------------------------------------------------------------------------
# Thawani (Oman alternate gateway). Set ENABLE_REAL_API=1 with live keys.
# ---------------------------------------------------------------------------
THAWANI_ENABLE_REAL_API=0
THAWANI_PUBLISHABLE_KEY=
THAWANI_SECRET_KEY=
THAWANI_WEBHOOK_SECRET=
THAWANI_BASE_URL=https://uatcheckout.thawani.om/api/v1

# Server/container-facing API URL used by Next.js server rendering.
API_INTERNAL_BASE_URL=http://backend:8000/api

DEFAULT_FROM_EMAIL=Enfhant Organic <no-reply@your-domain.com>
# Use smtp.EmailBackend in production. console.EmailBackend only prints to Docker logs.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# Gmail SMTP — requires a 16-char App Password (not your regular password).
# Enable 2FA on the Gmail account, then generate at: myaccount.google.com → Security → App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
EMAIL_USE_TLS=True

# Backup / Restore
BACKUP_DESTINATION=/home/deploy/enfhantOrganic/backups
BACKUP_ENCRYPTION_KEY=replace-with-a-strong-passphrase
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_REGION=
S3_PREFIX=enfantorganic/backups
