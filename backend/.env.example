# REQUIRED — generate a fresh value, never commit a real key:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=
# DEBUG must be 0 in any non-local environment. Local dev: set to 1 in your .env (not here).
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
# Production: must be 1. Settings default these to 1 when DEBUG=0.
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_SESSION_COOKIE_SECURE=1
DJANGO_CSRF_COOKIE_SECURE=1
DJANGO_SESSION_COOKIE_HTTPONLY=1
DJANGO_CSRF_COOKIE_HTTPONLY=1
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_SECURE_CONTENT_TYPE_NOSNIFF=1
DJANGO_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
DJANGO_X_FRAME_OPTIONS=DENY
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=1
DJANGO_SECURE_HSTS_PRELOAD=1

# Rate limits — tightened for production
DRF_ANON_RATE=60/min
DRF_USER_RATE=600/min
DRF_AUTH_RATE=5/min
DRF_PASSWORD_RESET_RATE=3/hour
DRF_CHECKOUT_RATE=30/hour
DRF_PAYMENT_RATE=30/hour
DRF_ORDER_LOOKUP_RATE=5/hour
DRF_WEBHOOK_RATE=120/min

# REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
REVALIDATION_SECRET=
FRONTEND_INTERNAL_URL=http://127.0.0.1:3000
# Public storefront base URL (used in password reset and order tracking links sent by email)
FRONTEND_PUBLIC_URL=http://127.0.0.1:3000

# Admin CSV export caps — protect against mass data exfiltration
ADMIN_CSV_MAX_ROWS=10000

# Redis (production must include a strong password)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432

DEFAULT_FROM_EMAIL=no-reply@example.com
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# ── Paymob Payment Gateway ──────────────────────────────────────────────────
# Get these from https://accept.paymob.com → Settings → Account Info
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=
PAYMOB_CURRENCY=EGP
PAYMOB_BASE_URL=https://accept.paymob.com/api

# Paymob Apple Pay (optional — only needed if you offer Apple Pay on the cart)
# Request these from your Paymob account manager.
PAYMOB_APPLE_PAY_INTEGRATION_ID=
PAYMOB_APPLE_PAY_IFRAME_ID=

# ── Region-scoped Paymob credentials (OM / SA / AE) ─────────────────────────
# The global PAYMOB_* vars above act as the Oman/default config. To offer
# Paymob in Saudi Arabia or the UAE, create a SEPARATE integration in the
# Paymob dashboard for that country/currency and fill its values below.
# Paymob only appears for a region once its integration_id + iframe_id +
# hmac_secret are set — SAR/AED orders are NEVER routed through the OMR
# integration. api_key is account-level and falls back to PAYMOB_API_KEY.
# Oman normally needs nothing here (it uses the global vars above):
PAYMOB_INTEGRATION_ID_OM=
PAYMOB_IFRAME_ID_OM=
PAYMOB_HMAC_SECRET_OM=
PAYMOB_BASE_URL_OM=https://oman.paymob.com/api
PAYMOB_CURRENCY_OM=OMR
# Saudi Arabia (fill once a SAR Paymob integration exists):
PAYMOB_API_KEY_SA=
PAYMOB_INTEGRATION_ID_SA=
PAYMOB_IFRAME_ID_SA=
PAYMOB_HMAC_SECRET_SA=
PAYMOB_BASE_URL_SA=https://ksa.paymob.com/api
PAYMOB_CURRENCY_SA=SAR
# UAE (fill once an AED Paymob integration exists):
PAYMOB_API_KEY_AE=
PAYMOB_INTEGRATION_ID_AE=
PAYMOB_IFRAME_ID_AE=
PAYMOB_HMAC_SECRET_AE=
PAYMOB_BASE_URL_AE=https://uae.paymob.com/api
PAYMOB_CURRENCY_AE=AED

