PAYTABS_PROFILE_ID=
PAYTABS_SERVER_KEY=
PAYTABS_CLIENT_KEY=
PAYTABS_BASE_URL=https://secure.paytabs.sa
PAYTABS_RETURN_BASE_URL=https://enfantorganic.itwing.cloud
PAYTABS_CALLBACK_BASE_URL=https://enfantorganic.itwing.cloud

