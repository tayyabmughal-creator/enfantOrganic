HYPERPAY_ENTITY_ID=
HYPERPAY_ACCESS_TOKEN=
HYPERPAY_BASE_URL=https://eu-prod.oppwa.com

# ── Telr (placeholder config) ──────────────────────────────────────────────
TELR_STORE_ID=
TELR_AUTH_KEY=
TELR_BASE_URL=https://secure.telr.com

