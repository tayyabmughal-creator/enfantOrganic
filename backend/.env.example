# ── Backup / Restore ────────────────────────────────────────────────────────
BACKUP_DESTINATION=./backups
BACKUP_ENCRYPTION_KEY=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_REGION=
S3_PREFIX=enfantorganic/backups
